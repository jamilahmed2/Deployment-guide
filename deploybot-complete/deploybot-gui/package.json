{
  "name": "deploybot-desktop",
  "version": "1.0.0",
  "description": "DeployBot Desktop - Visual deployment automation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never"
  },
  "keywords": ["deployment", "ssh", "automation", "devops"],
  "author": "DeployBot",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "ansi-to-html": "^0.7.2"
  },
  "build": {
    "appId": "com.deploybot.desktop",
    "productName": "DeployBot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!deploybot/**/*.pyc",
      "!deploybot/**/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "../deploybot",
        "to": "deploybot",
        "filter": ["**/*", "!**/*.pyc", "!**/__pycache__/**"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
